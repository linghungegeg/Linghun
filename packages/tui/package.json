{
  "name": "@linghun/tui",
  "version": "0.1.42",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "!dist/**/*.test.*", "!dist/**/tsconfig.tsbuildinfo"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup \"src/**/*.ts\" \"src/**/*.tsx\" \"!src/**/*.test.ts\" --format esm --clean && tsc -p tsconfig.json --emitDeclarationOnly --noEmit false --tsBuildInfoFile dist/tsconfig.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "1.59.0",
    "@linghun/config": "0.1.8",
    "@linghun/core": "0.1.8",
    "@linghun/ink-runtime": "0.1.1",
    "@linghun/providers": "0.1.18",
    "@linghun/shared": "0.1.11",
    "@linghun/tools": "0.1.11",
    "cli-highlight": "^2.1.11",
    "marked": "^18.0.5",
    "react": "^19.2.6"
  },
  "optionalDependencies": {
    "@linghun/codebase-memory-darwin-arm64": "0.1.0",
    "@linghun/codebase-memory-darwin-x64": "0.1.0",
    "@linghun/codebase-memory-linux-x64": "0.1.0",
    "@linghun/codebase-memory-win32-x64": "0.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15"
  }
}
