{
  "name": "@linghun/tui",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup \"src/**/*.ts\" \"src/**/*.tsx\" \"!src/**/*.test.ts\" --format esm --clean && tsc -p tsconfig.json --emitDeclarationOnly --noEmit false --tsBuildInfoFile dist/tsconfig.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "1.59.0",
    "@linghun/config": "workspace:*",
    "@linghun/core": "workspace:*",
    "@linghun/providers": "workspace:*",
    "@linghun/shared": "workspace:*",
    "@linghun/tools": "workspace:*",
    "ink": "^7.0.3",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.15"
  }
}
